# Per-instance secrets. Copy to /etc/marsad/<instance>.env (chmod 600) — e.g.
# /etc/marsad/host.env and /etc/marsad/network.env. The installer writes these for you.
#
# Slack bot token with chat:write. Leave blank to disable Slack (panel still works).
MARSAD_SLACK_TOKEN=xoxb-your-bot-token
# Channel or DM id to post to (e.g. C0XXXXXXX for a channel, D…/U… for a DM).
MARSAD_SLACK_CHANNEL=
# Admin token required to change settings via the panel (and REQUIRED for the host
# "stop top consumers" action). Strongly recommended when the panel is reachable on
# the network (the default bind is 0.0.0.0). Blank = no auth (stop-top disabled).
MARSAD_PANEL_TOKEN=
#
# --- router/network instance only (mode = "network") -------------------------
# The router admin password. Stored 0600, never logged or shown in the panel.
# A wrong value only disables the WAN block (one alert) — it never retries into a
# router lockout. Leave unset for host instances.
MARSAD_ROUTER_PASSWORD=
