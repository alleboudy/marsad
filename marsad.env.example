# Copy to /etc/marsad/marsad.env (chmod 600). The installer writes this for you.
#
# Slack bot token with chat:write. Leave blank to disable Slack (panel still works).
MARSAD_SLACK_TOKEN=xoxb-your-bot-token
# Channel or DM id to post to (e.g. C0XXXXXXX for a channel, D…/U… for a DM).
MARSAD_SLACK_CHANNEL=
# Admin token required to change settings via the panel. Strongly recommended when
# the panel is reachable on the network (the default bind is 0.0.0.0). Blank = no auth.
MARSAD_PANEL_TOKEN=
